{
  "schema_version": 1,
  "policy": {
    "algorithm": "blake3-256",
    "dimensions": ["structure", "names", "constants", "types", "trace_events"],
    "view_modes": ["identity_bound", "anonymous_shape"],
    "cycle_policies": ["reject", "non_recursive_graph_edges", "condense_scc"]
  },
  "fixtures": [
    {
      "name": "rename_only",
      "mutation": "local name b -> c",
